# ============================================================
# sniffnsnooz - Example Environment Variables Template
# ============================================================
# This file is safe to commit to version control.
# It shows all required env variables WITHOUT real values.
# Developers should copy this to .env.local and fill in values.
# ============================================================

# ---------------------------
# DATABASE (MongoDB)
# ---------------------------
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sniffnsnooz

# ---------------------------
# AUTH (JWT)
# ---------------------------
JWT_SECRET=<your_jwt_secret_min_32_chars>

# ---------------------------
# FIREBASE (Client SDK)
# ---------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=<your_firebase_api_key>
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=<project>.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=<your_project_id>
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=<project>.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<your_sender_id>
NEXT_PUBLIC_FIREBASE_APP_ID=<your_app_id>

# ---------------------------
# GOOGLE API (Places / Reviews)
# ---------------------------
GOOGLE_PLACES_API_KEY=<your_google_places_api_key>
GOOGLE_PLACE_ID=<your_google_place_id>

# ---------------------------
# CLOUDINARY (Image Hosting)
# ---------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# ---------------------------
# GOOGLE GENERATIVE AI (Gemini)
# ---------------------------
GOOGLE_AI_API_KEY=<your_gemini_api_key>

# ---------------------------
# ADMIN CREDENTIALS
# ---------------------------
ADMIN_EMAIL=<admin_email>
ADMIN_PASSWORD=<admin_password>

# ---------------------------
# APP SETTINGS
# ---------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
